meta {
  name: add email for escalation
  type: http
  seq: 14
}

post {
  url: {{backend_base_url}}/api/v1/chat/tickets/b558b5ba-39ca-4b70-b3d9-b83ef2f7a35e/email
  body: json
  auth: bearer
}

auth:bearer {
  token: {{anonymous_key}}
}

body:json {
  {
    "ticket_id":"b558b5ba-39ca-4b70-b3d9-b83ef2f7a35e",
    "email":{{test_email}}
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
