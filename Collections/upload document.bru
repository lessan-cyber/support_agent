meta {
  name: upload document
  type: http
  seq: 4
}

post {
  url: {{backend_base_url}}/api/v1/documents/upload
  body: multipartForm
  auth: inherit
}

headers {
  accept: application/json
  Authorization: {{token}}
}

body:multipart-form {
  file: @file(/run/user/1000/doc/36d9fe0e/Automation Cheat Sheet 2.0.pdf)
}

settings {
  encodeUrl: false
  timeout: 0
}
