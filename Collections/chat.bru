meta {
  name: chat
  type: http
  seq: 5
}

post {
  url: {{backend_base_url}}/api/v1/chat/stream
  body: json
  auth: bearer
}

auth:bearer {
  token: {{anonymous_key}}
}

body:json {
  {
    "content":"How can I set up a direct JDBC connection from LibreOffice Base to a MariaDB 10.6 database with SSL encryption, using a custom truststore, while maintaining proper transaction isolation levels? I need the exact connection string syntax and steps to configure the JDBC driver in LibreOffice on Ubuntu 22.04."
  }  
}

settings {
  encodeUrl: true
  timeout: 0
}
